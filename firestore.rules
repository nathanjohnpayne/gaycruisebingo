rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    // Admin uids listed in the event doc's `admins` array.
    function isAdmin(eventId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.admins;
    }
    // A `days/{dayIndex}` path segment is canonical only when it round-trips
    // through int(): `string(int(dayIndex)) == dayIndex`. This rejects numerically
    // equivalent aliases like `00`/`01`/`+0` that `int()` would still coerce to a
    // valid list index (Codex P2). Without it, `/days/00/...` reads Day 0's
    // `unlockAt` yet lives at a distinct doc path, minting a PARALLEL Day-0 board
    // or a second write-once `firstBingo` honor slot under an alias — duplicating
    // the one-doc-per-Day contract. Non-numeric segments make `int()` error, which
    // denies (the safe default).
    function isCanonicalDay(dayIndex) {
      return dayIndex == string(int(dayIndex));
    }

    // Server-owned intake queue. Players submit through the callable Function,
    // which validates/rate-limits with the Admin SDK; direct reads and writes
    // would expose screenshots and allow report metadata to be forged.
    match /bugReports/{reportId} {
      allow read, write: if false;
    }

    match /bugReportRateLimits/{uid} {
      allow read, write: if false;
    }

    // Global user profiles.
    match /users/{uid} {
      allow read: if signedIn();
      // Honor-system 18+ self-attestation (ADR 0001): a User records their OWN
      // `attestedAdultAt` — a self-statement, not identity verification — so the
      // existing self-write allowance covers it. When present it must be a numeric
      // ms-epoch stamp; a cross-user write is denied by isOwner. Split from a bare
      // `allow write` so delete stays permitted without tripping the create/update
      // validation against the (null) delete payload.
      allow create, update: if isOwner(uid)
        && (!('attestedAdultAt' in request.resource.data)
            || request.resource.data.attestedAdultAt is number);
      allow delete: if isOwner(uid);
    }

    match /events/{eventId} {
      allow read: if signedIn();
      // Only admins can change event config (theme default, claimMode, admins,
      // settings, bannedUids). `settings.reportHideThreshold` is load-bearing
      // (ADR 0004): when the write carries `settings`, its `reportHideThreshold`
      // must be a number. `blackoutEnabled` was dropped as dead config (ADR 0004)
      // and is intentionally NOT reintroduced to the schema here.
      //
      // `bannedUids` is the ban surface (#113): a presentational, event-scoped
      // hide/mute roster (ADR 0004 Phase 0), NOT hard access revocation —
      // server-authoritative enforcement is #43/#44. It lives HERE, on the
      // already-admin-writable event doc, rather than opening any write path into
      // owner-only users/{uid} (which stays owner-only — the anti-schema-smuggling
      // guarantee). When a write touches `bannedUids` it must be:
      //   - a LIST (a scalar/map ban field is rejected);
      //   - SIZE-CAPPED at 1000 — a sane ceiling far above any real event roster
      //     that still bounds the single event doc well under Firestore's 1 MiB
      //     limit and keeps every admin config write cheap to validate. banUser
      //     (#108) appends one uid at a time, so the cap is a runaway/abuse guard,
      //     not an expected-size limit;
      //   - DISJOINT from `admins` — a banned uid must never also be an admin
      //     (`!bannedUids.hasAny(admins)`), so a ban cannot silently target a
      //     co-admin. `admins` here is the RESULTING roster in the same write.
      // We validate the RESULTING `bannedUids` state (not the diff), so an
      // arrayUnion/arrayRemove partial update — what banUser/unbanUser (#108) will
      // use so a ban write never clobbers other event config — is accepted without
      // requiring the whole doc be rewritten; other config fields stay protected by
      // the isAdmin gate (non-admins are denied outright). Residual: rules can't
      // iterate a list, so per-element string-typing of bannedUids is not
      // expressible here — the #108 writer supplies real uids and the disjoint +
      // list + cap checks bound the abuse surface. Delete is split out so it never
      // has to satisfy the settings/bannedUids shape checks.
      allow create, update: if isAdmin(eventId)
        && (!('settings' in request.resource.data)
            || request.resource.data.settings.reportHideThreshold is number)
        && (!('bannedUids' in request.resource.data)
            || (request.resource.data.bannedUids is list
                && request.resource.data.bannedUids.size() <= 1000
                && !request.resource.data.bannedUids.hasAny(request.resource.data.admins)));
      allow delete: if isAdmin(eventId);

      // Community-editable prompt pool.
      match /items/{itemId} {
        // Non-admins read only visible ('active') Prompts; a server-hidden Prompt
        // is moderation-only, readable by admins (#43 F4, ADR 0004 Phase 1). This
        // MIRRORS the proofs read rule so the item (Prompt) hide is authoritative,
        // not merely presentational: without it a hidden Prompt's `text` stayed
        // directly fetchable by any signed-in client. The player-facing item query
        // (useItems / joinAndDeal) filters `where('status','==','active')` so its
        // collection read is allowed under this rule; the admin console query
        // (useAllItems) reads all statuses via the isAdmin arm. A single-field
        // `status` equality — no composite index (firestore.indexes.json untouched).
        //
        // Phase 1.5 approval flow (daily-cards-spec § "Item pools and the approval
        // flow"): the pool widens `status` to include 'pending' and 'rejected'. A
        // `pending` submission is "invisible everywhere except the Admin queue and
        // (as 'pending review') to their submitter" — so its OWN creator
        // (createdBy == auth.uid) may read it back while it waits, but no other
        // non-admin can. A `rejected` item is "kept for audit, hidden from all
        // non-admins" — including its ORIGINAL submitter once rejected — so it
        // falls through to the admin-only arm (no submitter carve-out). This is
        // why the carve-out is `status == 'pending'` ONLY, not `pending || rejected`.
        allow read: if signedIn() && (
          isAdmin(eventId)
          || resource.data.status == 'active'
          || (resource.data.status == 'pending' && resource.data.createdBy == request.auth.uid)
        );
        // Anyone signed in can add an item (basic validation).
        allow create: if signedIn()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 80
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.status == 'active'
          && request.resource.data.reportCount == 0
          && request.resource.data.spicy is bool;
        // Report = increment reportCount by 1 only; admins can do anything.
        //
        // `status` is SERVER-AUTHORITATIVE for the community-hide transition
        // (#43, ADR 0004 Phase 1). A non-admin's ONLY update is the report path,
        // and `hasOnly(['reportCount'])` bounds it to `reportCount` alone — so a
        // non-admin can NEVER set `status: 'hidden'` (or any status) here. The
        // Phase-1 auto-hide is written exclusively by the `hideItemAtThreshold`
        // Cloud Function via the admin SDK (which BYPASSES these rules) once
        // reportCount crosses `settings.reportHideThreshold`; admins retain the
        // manual hide/restore via the `isAdmin(eventId)` branch. This is the
        // authoritative promotion of the Phase-0 presentational `isReportHidden`
        // filter — pinned by tests/rules/w4-server-authoritative-hide.test.ts.
        allow update: if isAdmin(eventId)
          || (signedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount'])
              && request.resource.data.reportCount == resource.data.reportCount + 1);
        allow delete: if isAdmin(eventId);
      }

      // Membership + denormalized stats. Self-writable BY DESIGN (ADR 0001):
      // Marks are client-authoritative, so a Player writes their OWN stats
      // (bingoCount, squaresMarked, firstBingoAt) directly. This is the
      // honor-system trust model, NOT a hole to close — a reviewer who "fixes"
      // it by gating stat writes behind a Cloud Function has misread the design.
      // #40 deliberately removed the server recompute that implied otherwise;
      // any Phase-1 recompute is consistency/repair, never integrity/anti-cheat.
      // Cross-Player writes stay denied by isOwner(uid); admins may moderate.
      match /players/{uid} {
        allow read: if signedIn();
        allow create, update: if isOwner(uid) || isAdmin(eventId);
        allow delete: if isAdmin(eventId);
      }

      // Phase 1.5 day-scoped model (daily-cards-spec § "Data model" / "Security
      // rules and functions"): Boards and the per-day honor doc move under
      // `days/{dayIndex}`. `days` is an ARRAY field on the Event doc (a DayDef[],
      // #200/#201), NOT a subcollection — there is no `days/{dayIndex}` document —
      // so these subcollections hang off a path segment whose {dayIndex} we use to
      // index into that array for the Day's `unlockAt`.
      match /days/{dayIndex} {
        // A Player's Board (layout + bingo progress) for ONE Day is PRIVATE to its
        // owner (ADR 0002) and, like players/{uid}, self-writable BY DESIGN
        // (ADR 0001): the owner reads and writes their own frozen card directly
        // under the honor-system model. Do NOT lock these writes down — self-write
        // is the intended trust model, not a gap. Phase 1.5 adds one thing on top:
        // a TIME gate. A Board write (a deal that creates the doc, or a mark that
        // updates the owner's own doc) is allowed only at/after this Day's
        // `unlockAt`, read from `days[int(dayIndex)].unlockAt` on the Event doc
        // (the DayDef[] array, indexed by the path's dayIndex — `int()` coerces the
        // string segment to the numeric list index). `unlockAt` is a millisecond
        // epoch NUMBER (DayDef.unlockAt, src/types.ts), so the left side must be
        // `request.time.toMillis()` — comparing the raw `request.time` timestamp to
        // a number is a type mismatch that evaluates to an error and denies EVERY
        // post-unlock write (Codex P1). An out-of-range dayIndex makes the lookup
        // error, which denies — the safe default. Reads stay ungated so an
        // owner/admin can always inspect existing Board state. The "doc doesn't
        // exist (deal) or is the owner's (marks)" split in the spec both reduce to
        // isOwner(uid): the doc path is boards/{uid} either way.
        match /boards/{uid} {
          allow read: if isOwner(uid) || isAdmin(eventId);
          allow write: if (isOwner(uid) || isAdmin(eventId))
            && isCanonicalDay(dayIndex)
            && request.time.toMillis() >= get(/databases/$(database)/documents/events/$(eventId)).data.days[int(dayIndex)].unlockAt;
        }

        // Per-day First-to-BINGO honor doc: { firstBingo: { uid, displayName, at } }
        // at events/{eventId}/days/{dayIndex}/meta/{metaId} (one doc, id == the
        // encoded dayIndex). WRITE-ONCE, mirroring the moments/{momentId}
        // immutability pattern: `create` is allowed once (no prior doc) by the
        // achieving Player (firstBingo.uid == auth.uid — own-attributed, "written
        // via the same client path that posts first-bingo Moments today"), and
        // there is NO `update` path at all. A second write to the SAME day-meta doc
        // is therefore a doc-exists update, denied for EVERYONE including admins —
        // the per-day honor cannot be reassigned once claimed, exactly like the
        // deny-all update on a Moment. Public read (the honor is pinned on that
        // day's view); delete stays admin-only for moderation.
        //
        // The honor doc id is BOUND to its Day: `metaId == dayIndex` (Codex P2).
        // The type contract (src/types.ts) fixes the single canonical doc at
        // `meta/{dayIndex}` — one honor per Day. Without the binding a player could
        // write `meta/<anything>` under a self-attributed payload, minting parallel
        // honor docs at arbitrary ids and duplicating the write-once-per-day slot.
        //
        // The create is ALSO gated on this Day's `unlockAt`, exactly like the Board
        // write above (Codex P2). Because the honor is write-once with no update
        // path, an ungated create let a direct-SDK caller pre-create (squat) a
        // FUTURE day's canonical `meta/{dayIndex}` before it unlocks, permanently
        // claiming tomorrow's First-to-BINGO until an admin deletes it. Gating the
        // create on `request.time.toMillis() >= day.unlockAt` (a ms-epoch number,
        // same coercion as the Board gate) closes the squat: the honor can only be
        // claimed once its Day is live.
        match /meta/{metaId} {
          allow read: if signedIn();
          allow create: if signedIn()
            && metaId == dayIndex
            && isCanonicalDay(dayIndex)
            && request.time.toMillis() >= get(/databases/$(database)/documents/events/$(eventId)).data.days[int(dayIndex)].unlockAt
            && request.resource.data.firstBingo.uid == request.auth.uid
            && request.resource.data.firstBingo.displayName is string
            && request.resource.data.firstBingo.displayName.size() > 0
            && request.resource.data.firstBingo.displayName.size() <= 100
            && request.resource.data.firstBingo.at is number;
          allow delete: if isAdmin(eventId);
        }
      }

      // Proofs (Phase 1). Owner-created; reportable; admin-moderated.
      match /proofs/{proofId} {
        // Non-admins can read only visible ('active') proofs; hidden/flagged
        // proofs are moderation-only and readable by admins.
        allow read: if signedIn() && (isAdmin(eventId) || resource.data.status == 'active');
        // Constrain the payload like /items: the uploader owns the doc, only the
        // known fields are allowed, the proof starts visible + unreported, and
        // moderation fields (visionFlag, thumbURL) must be server-set, not client.
        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.keys().hasOnly([
               'uid', 'displayName', 'photoURL', 'type', 'cellIndex', 'itemText',
               'storagePath', 'mediaURL', 'thumbURL', 'text', 'createdAt',
               'reportCount', 'status', 'visionFlag'
             ])
          && request.resource.data.type in ['photo', 'audio', 'text']
          && request.resource.data.itemText is string
          && request.resource.data.itemText.size() <= 200
          && request.resource.data.cellIndex is number
          && request.resource.data.cellIndex >= 0
          && request.resource.data.cellIndex <= 24
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 100
          && (request.resource.data.photoURL == null || request.resource.data.photoURL is string)
          // createdAt is client-set and the feed sorts by it desc; require a
          // numeric, near-now value so a far-future stamp can't pin the feed.
          && request.resource.data.createdAt is number
          && request.resource.data.createdAt <= request.time.toMillis() + 60000
          && request.resource.data.createdAt >= request.time.toMillis() - 86400000
          // admin_confirmed-mode proofs start 'pending' (admin-only readable per the
          // read rule) until an admin confirms the claim; honor/proof_required proofs
          // start 'active'. A 'pending' proof is never publicly visible.
          && request.resource.data.status in ['active', 'pending']
          && request.resource.data.reportCount == 0
          && request.resource.data.visionFlag == null
          && request.resource.data.thumbURL == null
          // Proof media must be the EXACT Storage object named after this proof's
          // OWN doc id — proofs/{eventId}/{uid}/{proofId}.{ext} — which is what
          // uploadProofMedia() writes (jpg for photo, webm for audio) and what
          // moderateProof() scans. Pinning to the exact object (not just the
          // uploader's folder) stops a client from setting storagePath to one
          // object and mediaURL to a DIFFERENT, unscanned object in their folder
          // (e.g. an unscanned .png) to bypass the Storage size/content-type rules
          // and the moderateProof Vision scan. The client-supplied mediaURL must be
          // the getDownloadURL for that same object. Text proofs carry no media.
          // Residual gap (not expressible here): rules can't confirm the object
          // actually exists or that the URL token is valid, and this pins the
          // standard getDownloadURL host (firebasestorage.googleapis.com); the
          // Storage rules + moderation trigger cover the object side.
          && (
               (request.resource.data.type == 'text'
                 && request.resource.data.storagePath == null
                 && request.resource.data.mediaURL == null)
               ||
               (request.resource.data.type == 'photo'
                 && request.resource.data.storagePath == 'proofs/' + eventId + '/' + request.auth.uid + '/' + proofId + '.jpg'
                 && request.resource.data.mediaURL is string
                 && request.resource.data.mediaURL.matches('^https://firebasestorage[.]googleapis[.]com/v0/b/[^/]+/o/proofs%2F' + eventId + '%2F' + request.auth.uid + '%2F' + proofId + '[.]jpg([?].*)?$'))
               ||
               (request.resource.data.type == 'audio'
                 && request.resource.data.storagePath == 'proofs/' + eventId + '/' + request.auth.uid + '/' + proofId + '.webm'
                 && request.resource.data.mediaURL is string
                 && request.resource.data.mediaURL.matches('^https://firebasestorage[.]googleapis[.]com/v0/b/[^/]+/o/proofs%2F' + eventId + '%2F' + request.auth.uid + '%2F' + proofId + '[.]webm([?].*)?$'))
             );
        // Report = increment reportCount by 1 only (same as /items). `status` is
        // SERVER-AUTHORITATIVE for the community-hide transition (#43, ADR 0004
        // Phase 1): `hasOnly(['reportCount'])` bounds a non-admin (including the
        // proof's OWN uploader) to `reportCount` alone, so no client can set
        // `status: 'hidden'` — nor un-hide by setting it back to 'active'. The
        // Phase-1 auto-hide is written exclusively by the `hideProofAtThreshold`
        // Cloud Function via the admin SDK (bypasses these rules) once reportCount
        // crosses `settings.reportHideThreshold`; admins keep manual hide/restore
        // and confirm-claim (`status: 'active'`) via the `isAdmin(eventId)` branch.
        // Pinned by tests/rules/w4-server-authoritative-hide.test.ts.
        allow update: if isAdmin(eventId)
          || (signedIn()
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount'])
              && request.resource.data.reportCount == resource.data.reportCount + 1);
        allow delete: if isOwner(resource.data.uid) || isAdmin(eventId);
      }

      // admin_confirmed-mode claims: a player creates a claim for their own square;
      // admins read the queue and resolve (confirm/reject) them.
      match /claims/{claimId} {
        allow read: if isAdmin(eventId) || isOwner(resource.data.uid);
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if isAdmin(eventId);
      }

      // Per-Prompt Tally (ADR 0002). A Mark is PRIVATE on the Board but PUBLIC as an
      // attributed per-Prompt tally: every Mark — proofed or not — publishes WHO
      // marked the Prompt. That public disclosure is the "see who else got this
      // square" feature, not a leak; there is no anonymity by design.
      // This is the PUBLIC half of the honor-system model whose PRIVATE half is
      // the self-writable Board/stats above (ADR 0001): a Player self-records the
      // Mark on their Board AND self-publishes their own attributed Tally entry
      // (markers/{uid} below). A bare Mark publishes ONLY here — nothing lands on
      // the Feed (moments/**) without a Moment. Documented, not altered, per #18:
      // do not lock down Tally reads or the owner-only marker writes.
      match /tally/{itemId} {
        // The denormalized aggregate ({ itemId, count, markers }) that backs the
        // Square badge is public-read; in Phase 0 the badge count is derived from
        // the `markers` subcollection below, and the aggregate doc is maintained
        // admin/Cloud-Function-side (Phase 1), never client-forged.
        allow read: if signedIn();
        allow write: if isAdmin(eventId);

        // Attribution lives here: the entry doc id IS the marker's uid, so a Player
        // may add/update/remove ONLY their own entry and a forged-attribution write
        // is denied. Reads are public (ADR 0002).
        match /markers/{markerUid} {
          allow read: if signedIn();
          allow create, update: if isOwner(markerUid)
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.displayName is string
            && request.resource.data.displayName.size() > 0
            && request.resource.data.displayName.size() <= 100
            && request.resource.data.markedAt is number;
          // Unmarking removes exactly that Player's entry; admins can moderate.
          allow delete: if isOwner(markerUid) || isAdmin(eventId);
        }
      }

      // Doubts (ADR 0001): a Player publicly asks ANOTHER to back up a marked
      // Prompt — social pressure ("pics or it didn't happen"), never a gate. It
      // never blocks, unmarks, or discounts the Mark; attaching a Proof merely
      // satisfies it. Public read.
      match /doubts/{doubtId} {
        allow read: if signedIn();
        // Raised BY the caller, ON someone else's Mark (no self-doubt); a forged
        // `fromUid` is denied.
        allow create: if signedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.targetUid is string
          && request.resource.data.targetUid != request.auth.uid
          && request.resource.data.itemId is string
          // Bind the doc id to the payload triple — `${fromUid}_${targetUid}_
          // ${itemId}` (fromUid == auth.uid above) — because raiseDoubt writes
          // this DETERMINISTIC id as its cross-client duplicate backstop (Codex
          // P2, PR #106 round 2): one slot per (doubter, target, Prompt), so a
          // second raise of the same triple is a doc-exists update, denied below
          // for the doubter. WITHOUT the binding any signed-in Player could
          // pre-create ANOTHER doubter's slot (the id was unconstrained; the
          // payload their own, valid) and permanently deny that Player's raise —
          // the same denial-of-service shape the moments id↔kind binding closed
          // (#103/#105). `_` joins the triple: it appears in no Firebase-minted
          // uid or Firestore auto-id, and the id is constructed, never parsed.
          && doubtId == request.auth.uid + '_' + request.resource.data.targetUid + '_' + request.resource.data.itemId
          // The target must have a STANDING Mark on the Prompt: their attributed
          // Tally marker (tally/{itemId}/markers/{targetUid} — the PUBLIC half of
          // the Mark, ADR 0002, doc id == marker uid so this lookup is exact) must
          // exist at raise time (Codex P2, PR #106 round 3). A Doubt is an
          // accusation against a standing Mark — the spec's social model — so a
          // direct-write client can no longer pre-seed Doubts against (target,
          // Prompt) pairs the target never marked and ambush their badge the
          // moment they later mark that Prompt. Residual (accepted): this gates
          // CREATE only — a Doubt legitimately raised and then unmarked-away
          // survives as a doc (its marker deleted; rules never cascade), which
          // the display layer's dormant/reappear semantics already handle
          // (specs/w2-doubts.md finding 2); and an offline-queued raise whose
          // target unmarks before the queue drains is denied at drain time (the
          // client logs it as the benign once-only/denied path).
          && exists(/databases/$(database)/documents/events/$(eventId)/tally/$(request.resource.data.itemId)/markers/$(request.resource.data.targetUid))
          && request.resource.data.cellIndex is number
          // createdAt is client-set and is the satisfaction CUTOFF the derivation
          // compares Proof timestamps against (src/data/doubts.ts isDoubtSatisfied):
          // a Proof answers a Doubt only when proof.createdAt >= doubt.createdAt.
          // Bound it to the SAME +60s / -24h window of request.time that proofs +
          // moments use, so a bad clock or a forged far-future stamp can't make a
          // Doubt permanently UNANSWERABLE until that future instant (Codex P2,
          // PR #106 finding 3). The client writes Date.now() (in bounds by
          // construction); an offline Doubt drains with its ORIGINAL stamp, so a
          // >24h offline queue trips the lower bound (accepted residual — see
          // specs/w2-doubts.md, mirroring the moments offline-drain note).
          && request.resource.data.createdAt is number
          && request.resource.data.createdAt <= request.time.toMillis() + 60000
          && request.resource.data.createdAt >= request.time.toMillis() - 86400000;
        // The doubted Player (or an admin) marks it satisfied by attaching a Proof —
        // a social resolution recorded in `satisfied*`, not a gate on play (ADR 0001).
        allow update: if isAdmin(eventId)
          || (isOwner(resource.data.targetUid)
              && request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['satisfiedAt', 'satisfiedProofId']));
        allow delete: if isAdmin(eventId) || isOwner(resource.data.fromUid);
      }

      // Moments (ADR 0002): a broadcast of a big social beat (BINGO / Blackout /
      // First to BINGO) posted to the Feed. A bare Mark broadcasts nothing here.
      // Own-beat create only (a forged uid is denied); public read; fully immutable
      // (no update path); deletable by owner or admin.
      match /moments/{momentId} {
        allow read: if signedIn();
        allow create: if isOwner(request.resource.data.uid)
          && request.resource.data.kind in ['bingo', 'blackout', 'first_bingo']
          // Bind the doc id to the payload kind so a caller cannot squat an id with a
          // MISMATCHED kind (issue #103). Mirrors the writer's deterministic scheme
          // (src/data/moments.ts): the event-singleton `first_bingo` id must carry kind
          // 'first_bingo', and every per-Player id must be `${uid}-${kind}`
          // (`${uid}-bingo` / `${uid}-blackout`). Without it any signed-in Player could
          // create moments/first_bingo with a non-first_bingo kind: the read-side filter
          // (useData.ts hasCanonicalMomentId) hides it, but a Moment is fully immutable,
          // so the legitimate First-to-BINGO create then hits the deny-all `update` rule
          // on the same id and is denied FOREVER — a denial-of-ceremony squat (only
          // `first_bingo` is exposed; per-Player ids embed the writer's own uid and
          // create already requires isOwner). The read-side filter stays defense-in-depth.
          && (momentId == 'first_bingo'
                ? request.resource.data.kind == 'first_bingo'
                : momentId == request.resource.data.uid + '-' + request.resource.data.kind)
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() > 0
          && request.resource.data.displayName.size() <= 100
          // createdAt is client-set and the Feed sorts by it desc; require a
          // numeric, near-now value (same tolerance as proofs above: within +60s /
          // -24h of request.time) so a bad clock or a forged far-future stamp can't
          // pin a Moment above all Feed activity forever (Codex P2, PR #99 finding
          // 3). The client writes Date.now() — in bounds by construction; an offline
          // Moment drains with its ORIGINAL stamp, so a >24h offline queue would trip
          // the lower bound (accepted residual — see specs/w2-feed-moments.md).
          && request.resource.data.createdAt is number
          && request.resource.data.createdAt <= request.time.toMillis() + 60000
          && request.resource.data.createdAt >= request.time.toMillis() - 86400000;
        // No update path — a Moment is fully immutable (Codex P2, PR #99 finding 4).
        // The deterministic-id, create-only dedup the writer relies on (moments.ts:
        // `${uid}-bingo`, the `first_bingo` singleton) is only sound if a re-broadcast
        // to an existing id is DENIED for EVERYONE. An admin-writable update let an
        // admin-player's repeat broadcast become an authorized overwrite — clobbering
        // the first_bingo singleton under a stale-roster race. MomentDoc carries NO
        // moderation/status field (src/types.ts: kind/uid/displayName/photoURL/
        // createdAt), so there is nothing an update could legitimately change without
        // rewriting content; moderation here is delete-only. A moderation-only update
        // (a status field + a hasOnly() diff) is deferred to #37/#41, which own that
        // schema evolution.
        allow delete: if isAdmin(eventId) || isOwner(resource.data.uid);
      }
    }
  }
}
