# Copy to .env.local and fill from Firebase console:
# Project settings > General > Your apps > Web app > SDK setup and configuration
VITE_FIREBASE_API_KEY=
# Must be the origin the app is SERVED from (gaycruisebingo.com), NOT the Firebase
# console default gaycruisebingo.firebaseapp.com. Firebase hosts the OAuth handler
# at <authDomain>/__/auth/handler; when that origin differs from where the app
# runs, storage-partitioned mobile browsers (iOS in-app webviews, Safari ITP)
# can't read the pre-redirect sign-in state and Google sign-in dies with "Unable
# to process request due to missing initial state". Same-origin avoids the split.
VITE_FIREBASE_AUTH_DOMAIN=gaycruisebingo.com
VITE_FIREBASE_PROJECT_ID=gaycruisebingo
VITE_FIREBASE_STORAGE_BUCKET=gaycruisebingo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=849798007162
VITE_FIREBASE_APP_ID=
# Analytics > Data streams > Web > Measurement ID (G-XXXXXXX). Optional in dev.
VITE_FIREBASE_MEASUREMENT_ID=

# Which event/board this build points at (schema supports many; v1 uses one).
VITE_EVENT_ID=med-2026

# Optional (Phase 1): App Check reCAPTCHA Enterprise site key.
VITE_RECAPTCHA_SITE_KEY=

# PostHog client-side product analytics (runs alongside GA4). The `phc_` project
# key is client-safe/public. Leave VITE_POSTHOG_KEY blank to disable PostHog.
VITE_POSTHOG_KEY=
# Ingestion host. Prod routes events first-party through the reverse proxy at
# d.gaycruisebingo.com, which forwards ingestion plus `/static/*` and `/array/*`
# asset/config routes to PostHog US (#149). This is also the in-code default;
# set https://us.i.posthog.com only when a non-production build must bypass the
# proxy. The PostHog UI host is fixed to https://us.posthog.com in code.
VITE_POSTHOG_HOST=https://d.gaycruisebingo.com

# --- Cloud Functions config (issue #101) -------------------------------------
# The email notifier's config (EMAIL_FROM, ADMIN_NOTIFY_EMAIL, APP_BASE_URL, and
# the RESEND_API_KEY secret) is NOT read from this file. Firebase Functions v2
# loads params/dotenv from the functions source dir (firebase.json
# functions.source = "functions"), so those go in functions/.env — see
# functions/.env.example. Setting them here has no effect on the deployed
# functions.
