# Copy to .env.local and fill from Firebase console:
# Project settings > General > Your apps > Web app > SDK setup and configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=gaycruisebingo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gaycruisebingo
VITE_FIREBASE_STORAGE_BUCKET=gaycruisebingo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=849798007162
VITE_FIREBASE_APP_ID=
# Analytics > Data streams > Web > Measurement ID (G-XXXXXXX). Optional in dev.
VITE_FIREBASE_MEASUREMENT_ID=

# Which event/board this build points at (schema supports many; v1 uses one).
VITE_EVENT_ID=med-2026

# Optional (Phase 1): App Check reCAPTCHA Enterprise site key.
VITE_RECAPTCHA_SITE_KEY=

# PostHog client-side product analytics (runs alongside GA4). The `phc_` project
# key is client-safe/public. Leave VITE_POSTHOG_KEY blank to disable PostHog.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
