# Cloud Functions config (issue #101). Firebase Functions v2 loads dotenv/params
# from THIS directory (firebase.json sets functions.source = "functions") — NOT
# the repo-root .env. Copy to `functions/.env` (all environments) or
# `functions/.env.gaycruisebingo` (the per-project override, <projectId> from
# .firebaserc). Real .env files are gitignored; this template is committed.
#
# These are non-secret firebase-functions/params defineString values with safe
# defaults baked in — set them here only to override a default.

# From address for transactional email. Sends from the already-verified
# nathanpayne.com Resend domain (free-plan single-domain limit — no new DNS).
EMAIL_FROM=Gay Cruise Bingo <gaycruisebingo@nathanpayne.com>
# Optional shared-inbox override (comma-separated). Empty = notify the Event
# admins roster (resolved to verified Google emails) only.
ADMIN_NOTIFY_EMAIL=
# Base URL for the Admin-console deep link in notification emails.
APP_BASE_URL=https://gaycruisebingo.com

# RESEND_API_KEY is NOT an env var — it is a Google Secret Manager secret
# (defineSecret), set with `firebase functions:secrets:set RESEND_API_KEY`
# (value from the 1Password item "Resend API Key (gaycruisebingo)"). Never put
# it in this file.
