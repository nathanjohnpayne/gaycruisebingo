#!/usr/bin/env bash
# scripts/ci/check_sweep_unresolved_feedback
#
# Runs unit tests for the #236 weekly feedback sweep pipeline:
#
#   scripts/sweep-unresolved-feedback/enumerate.sh
#   scripts/sweep-unresolved-feedback/render.sh
#
# The tests stub `gh` via a PATH shim, so this check is hermetic: no
# network, no real auth. Mirrors the pattern of check_gh_as_author /
# check_sync_overrides.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

REQUIRED_FILES=(
  "scripts/sweep-unresolved-feedback/enumerate.sh"
  "scripts/sweep-unresolved-feedback/render.sh"
  "scripts/sweep-unresolved-feedback/target-repos.txt"
  ".github/workflows/weekly-feedback-sweep.yml"
  "tests/test_sweep_unresolved_feedback.sh"
)

# Consumer-safety guard (#601): repo_lint.yml is manifest-canonical, so
# consumers run this wrapper too — but the weekly sweep pipeline it
# checks is hub-only (never propagated; allow-listed in
# check_propagation_closure). SKIP only when EVERY sweep input AND the
# hub marker scripts/sync-to-downstream.sh are absent (the consumer
# shape; none of them propagate). Deliberately not a marker-first early
# exit (CodeRabbit Major on #624): with ANY sweep file present, the
# fail-closed presence loop below runs — hub-side marker loss can never
# silently disable this check.
_any_sweep_input_present=0
for rel in "${REQUIRED_FILES[@]}"; do
  if [ -f "$REPO_ROOT/$rel" ]; then
    _any_sweep_input_present=1
    break
  fi
done
if [ "$_any_sweep_input_present" -eq 0 ] \
   && [ ! -f "$REPO_ROOT/scripts/sync-to-downstream.sh" ]; then
  echo "check_sweep_unresolved_feedback: SKIP (consumer checkout: sweep pipeline files + scripts/sync-to-downstream.sh all absent; hub-only sweep pipeline)"
  exit 0
fi

FAILED=0
for rel in "${REQUIRED_FILES[@]}"; do
  full="$REPO_ROOT/$rel"
  if [ ! -f "$full" ]; then
    echo "check_sweep_unresolved_feedback: ERROR missing $rel" >&2
    FAILED=1
  fi
done

# Exec bit on the scripts.
for rel in scripts/sweep-unresolved-feedback/enumerate.sh scripts/sweep-unresolved-feedback/render.sh; do
  full="$REPO_ROOT/$rel"
  if [ -f "$full" ] && [ ! -x "$full" ]; then
    echo "check_sweep_unresolved_feedback: ERROR $rel not executable (chmod +x)" >&2
    FAILED=1
  fi
done

if [ "$FAILED" -ne 0 ]; then
  echo "check_sweep_unresolved_feedback: FAIL (file presence)"
  exit 1
fi

TEST="$REPO_ROOT/tests/test_sweep_unresolved_feedback.sh"
echo "check_sweep_unresolved_feedback: running $TEST"
if ! bash "$TEST"; then
  echo "check_sweep_unresolved_feedback: FAIL (tests)" >&2
  exit 1
fi

# Backfill driver (#566) is mergepath-only: scripts/sweep-unresolved-feedback/
# backfill.sh + its test are allow-listed in check_propagation_closure and never
# travel to consumers. Run the test where BOTH are present (the hub); skip
# cleanly where BOTH are absent (a consumer checkout). FAIL if exactly one is
# present — a broken script/test pairing, not a legitimate consumer state
# (Codex Phase-4b on #571: don't silently skip the regression suite).
BACKFILL_SCRIPT="$REPO_ROOT/scripts/sweep-unresolved-feedback/backfill.sh"
BACKFILL_TEST="$REPO_ROOT/tests/test_backfill_unresolved_feedback.sh"
if [ -f "$BACKFILL_SCRIPT" ] && [ -f "$BACKFILL_TEST" ]; then
  echo "check_sweep_unresolved_feedback: running $BACKFILL_TEST"
  if ! bash "$BACKFILL_TEST"; then
    echo "check_sweep_unresolved_feedback: FAIL (backfill tests)" >&2
    exit 1
  fi
elif [ -f "$BACKFILL_SCRIPT" ] || [ -f "$BACKFILL_TEST" ]; then
  echo "check_sweep_unresolved_feedback: FAIL (backfill script/test pairing broken — exactly one of backfill.sh / its test is present)" >&2
  exit 1
fi

echo "check_sweep_unresolved_feedback: PASS"
exit 0
