#!/usr/bin/env bash
# scripts/ci/check_bootstrap_board_and_summary — CI entry point for
# #156 sub-E / #207 tests.
#
# Wraps tests/test_bootstrap_board_and_summary.sh so the repo_lint
# workflow's "run all scripts/ci/check_*" loop picks it up. Mirrors
# the pattern used by check_bootstrap_github_infra. Missing test
# script is a hard error (matches the tightening applied to
# check_sync_overrides in #228 round 5).

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
TEST_SCRIPT="$REPO_ROOT/tests/test_bootstrap_board_and_summary.sh"

if [ ! -f "$TEST_SCRIPT" ]; then
  # Consumer-safety guard (#601): repo_lint.yml is manifest-canonical,
  # so consumers run this wrapper too — but the bootstrap suite it
  # wraps is hub-only (never propagated). scripts/sync-to-downstream.sh
  # is the standard hub marker (intentionally NOT propagated; same
  # disambiguator as check_sync_manifest). The marker is consulted ONLY
  # inside this missing-test branch (CodeRabbit Major on #624): both
  # absent → consumer checkout → SKIP; marker present → the hub lost
  # the test (accidental delete/rename) → hard error, preserving the
  # pre-#601 fail-closed hub behavior. Marker loss on the hub can
  # never silently disable this check: with the test present the
  # wrapper runs it regardless of the marker.
  if [ ! -f "$REPO_ROOT/scripts/sync-to-downstream.sh" ]; then
    echo "check_bootstrap_board_and_summary: SKIP (consumer checkout: wrapped test + scripts/sync-to-downstream.sh both absent; hub-only bootstrap suite)"
    exit 0
  fi
  echo "check_bootstrap_board_and_summary: ERROR (missing $TEST_SCRIPT)" >&2
  exit 1
fi

bash "$TEST_SCRIPT"
