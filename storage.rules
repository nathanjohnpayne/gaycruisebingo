rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function okImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 8 * 1024 * 1024;
    }
    function okAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 12 * 1024 * 1024;
    }

    // Custom avatars.
    match /avatars/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) && okImage();
    }

    // Proof media (Phase 1). Path scoped to the uploading user.
    match /proofs/{eventId}/{uid}/{file} {
      allow read: if signedIn();
      allow write: if isOwner(uid) && (okImage() || okAudio());
    }

    // Server-generated OG images are written by backend only (Phase 1).
    match /og/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
