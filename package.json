{
  "name": "gaycruisebingo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Gay Cruise Bingo — live multiplayer bingo PWA (Phase 0).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "test:functions": "npm --prefix functions install && vitest run --config vitest.functions.config.ts",
    "test:e2e": "scripts/test-e2e.sh",
    "test:synthetic": "playwright test --config playwright.synthetic.config.ts",
    "emulator": "firebase emulators:start --only auth,firestore,storage",
    "seed": "node scripts/seed.mjs",
    "verify:seed": "GOOGLE_CLOUD_PROJECT=gaycruisebingo VITE_EVENT_ID=med-2026 node scripts/seed.mjs --verify",
    "bugs:pull": "node scripts/bug-reports.mjs pull",
    "bugs:archive": "node scripts/bug-reports.mjs archive",
    "bugs:disposition": "node scripts/bug-reports.mjs disposition",
    "deploy": "scripts/deploy.sh",
    "deploy:hosting": "scripts/deploy.sh --only hosting",
    "pretest:e2e": "playwright install chromium"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.24.0",
    "posthog-js": "^1.399.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "fake-indexeddb": "^6.2.5",
    "firebase-admin": "^12.7.0",
    "firebase-tools": "^15.24.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "gaxios": {
      "uuid": "^11.1.1"
    },
    "@opentelemetry/core": "^2.8.0"
  }
}
