{
  "permissions": {
    "allow": [
      "Bash(scripts/gh-as-author.sh -- gh pr merge * --squash --delete-branch)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/gh-pr-guard.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/label-removal-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
